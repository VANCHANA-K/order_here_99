{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Runtime": {
    "EnableSwagger": true,
    "EnableFrontendDevCors": true,
    "ApplyMigrationsOnStartup": true,
    "SeedDemoDataOnStartup": true
  },
  "AuditLogs": {
    "DirectoryPath": "data/audit",
    "RetentionDays": 7,
    "AggregationPeriod": "Daily"
  },
  "ConnectionStrings": {
    "Default": "Data Source=qrfood.dev.db"
  }
}
